FROM node:20-alpine AS builder
RUN apk add --no-cache libc6-compat
RUN npm install -g pnpm turbo

WORKDIR /app
COPY . .
RUN pnpm install --frozen-lockfile
# Ensure NEXT_TELEMETRY_DISABLED is set to disable telemetry
ENV NEXT_TELEMETRY_DISABLED=1
RUN pnpm --filter="@trace/web..." build

FROM node:20-alpine AS runner
WORKDIR /app
ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1

RUN addgroup --system --gid 1001 nodejs
RUN adduser --system --uid 1001 nextjs

# Set the correct permission for prerender cache
# We copy from builder
COPY --from=builder /app/packages/web/.next/standalone ./
COPY --from=builder /app/packages/web/.next/static ./packages/web/.next/static
# Static assets in public/ (logo, manifest, icons) — standalone does NOT bundle these.
COPY --from=builder /app/packages/web/public ./packages/web/public

# Note: standalone mode places the server.js at the root of the workspace context,
# so the command will be `node packages/web/server.js` or `node server.js`
USER nextjs

EXPOSE 3000
ENV PORT=3000
ENV HOSTNAME="0.0.0.0"

CMD ["node", "packages/web/server.js"]
