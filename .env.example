# ─────────────────────────────────────────────────────────
# TRACE Environment Variables
# Copy to .env and fill in values before running.
# ─────────────────────────────────────────────────────────

# ── Database ─────────────────────────────────────────────
DATABASE_URL=postgresql://trace:trace@localhost:5432/trace

# ── Redis ────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── VeChain ──────────────────────────────────────────────
VECHAIN_NODE_URL=http://localhost:8669

# Deployer wallet private key (hex, with 0x prefix)
# Generate: openssl rand -hex 32
DEPLOYER_PRIVATE_KEY=0x

# Fee delegation service URL (optional — leave empty for dev)
FEE_DELEGATOR_URL=
# Local/Solo gas payer private key fallback. Leave empty when using FEE_DELEGATOR_URL.
FEE_DELEGATOR_PRIVATE_KEY=0x
# When true, passport anchoring fails if no fee delegator URL/private key is configured.
FEE_DELEGATION_REQUIRED=false

# Workshop showcase demo mode. When true, new passports get a real keccak256
# tamper-evident fingerprint marked "trust layer prepared" instead of a live
# VeChain transaction (no funded wallet / fee delegation required). NEVER enable in production.
DEMO_SIMULATE_ANCHOR=false

# Org custodial wallet encryption key. Use a long random secret per environment.
# For mainnet, replace this simple env-secret pattern with KMS/Vault-backed custody.
WALLET_ENCRYPTION_KEY=

# Admin VTHO monitoring thresholds, in wei.
VTHO_WARNING_THRESHOLD_WEI=10000000000000000000
VTHO_CRITICAL_THRESHOLD_WEI=1000000000000000000

# ── Contract Addresses ───────────────────────────────────
# Populated automatically after: pnpm --filter @trace/contracts deploy:solo
MATERIAL_REGISTRY_ADDRESS=
MARKETPLACE_ADDRESS=
CBT_ADDRESS=
QUALITY_ASSURANCE_ADDRESS=
IOT_ORACLE_ADDRESS=
GOVERNANCE_ADDRESS=
HUB_REGISTRY_ADDRESS=
CONTRACT_REGISTRY_ADDRESS=

# ── Object Storage (MinIO) ───────────────────────────────
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_PASSPORTS=passports
MINIO_BUCKET_REPORTS=reports
# Public-facing base URL for MinIO assets (e.g. https://storage.yourdomain.com)
# Required when assets must be accessible outside the internal network.
MINIO_PUBLIC_URL=

# ── Search (Meilisearch) ─────────────────────────────────
MEILISEARCH_URL=http://localhost:7700
MEILISEARCH_KEY=masterKey
# Set MEILI_ENV=production on production VPS (enables API key enforcement)
MEILI_ENV=development
MEILI_MASTER_KEY=masterKey

# ── Auth ─────────────────────────────────────────────────
# Generate: openssl rand -base64 48
JWT_SECRET=change-this-to-a-random-secret-at-least-32-chars
JWT_EXPIRY=7d

# Generic password assigned to seeded workshop attendee accounts.
# Used by: pnpm --filter @trace/db seed:workshop  (override with --password). Rotate after the event.
WORKSHOP_PASSWORD=TraceWorkshop2026!

# ── App ──────────────────────────────────────────────────
API_PORT=3001
WEB_URL=http://localhost:3000
API_URL=http://localhost:3001
# Public API origin used by the Next.js frontend.
# For same-origin deployments behind a reverse proxy, leave unset.
# If using a separate API domain, set explicitly (e.g. https://api-staging.example.com).
# NEXT_PUBLIC_API_URL=http://localhost:3001
# Public explorer base URL. Leave empty on Solo to use TRACE's mini-explorer.
# NEXT_PUBLIC_VECHAIN_EXPLORER_URL=https://explore-testnet.vechain.org
NODE_ENV=development
LOG_LEVEL=debug

# ── Docker host port mappings ────────────────────────────
# Host-side ports for `docker compose` (container ports are fixed). These let the
# SAME docker-compose.yml run on multiple environments without diverging — set
# per environment in that environment's .env. Defaults below are the PRODUCTION
# values, so production works without overrides; staging overrides them.
#   Production (default): API 3004, WEB 3003, THOR 8669, PG 15432, REDIS 16379, MINIO 19000/19001, MEILI 17700
#   Staging:              API 4004, WEB 4003, THOR 8670, PG 15433, REDIS 16380, MINIO 29000/29001, MEILI 17701
API_HOST_PORT=3004
WEB_HOST_PORT=3003
THOR_HOST_PORT=8669
POSTGRES_HOST_PORT=15432
REDIS_HOST_PORT=16379
MINIO_HOST_PORT=19000
MINIO_CONSOLE_HOST_PORT=19001
MEILI_HOST_PORT=17700
