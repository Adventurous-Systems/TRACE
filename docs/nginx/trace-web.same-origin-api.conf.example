##
## TRACE same-origin auth/API routing example
## - /api/* is proxied to Fastify API
## - all other paths are proxied to Next.js web
##
## Copy into your nginx site config and adjust hostnames/upstream ports.
##

upstream trace_web_upstream {
    server 127.0.0.1:3000;
    keepalive 32;
}

upstream trace_api_upstream {
    server 127.0.0.1:3001;
    keepalive 32;
}

server {
    listen 443 ssl http2;
    server_name trace-staging.adventurous.systems;

    # TLS config omitted for brevity (certs, ssl params)

    # API routes must hit Fastify, not Next.js.
    location /api/ {
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header Connection "";
        proxy_pass http://trace_api_upstream;
    }

    # Everything else goes to Next.js.
    location / {
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_cache_bypass $http_upgrade;
        proxy_pass http://trace_web_upstream;
    }
}
